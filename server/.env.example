# Copy this file to .env and fill in your real password.
# NEVER commit the real .env file to GitHub.

# ---- Option A: SRV format (default, what Atlas shows first) ----
# Works fine on most networks. If you get "querySrv ETIMEOUT", your network/DNS
# is blocking the SRV lookup — switch to Option B below instead.
MONGODB_URI=mongodb+srv://stayease:YOUR_REAL_PASSWORD@cluster0.kguu8fx.mongodb.net/placement-tracker?retryWrites=true&w=majority

# ---- Option B: Standard format (use this if Option A times out) ----
# Get this exact string from Atlas: Database -> Connect -> Drivers ->
# scroll down -> "Or Standard connection string" link (below the srv:// one shown by default).
# It lists the shard hosts directly and skips the SRV DNS lookup entirely.
# MONGODB_URI=mongodb://stayease:YOUR_REAL_PASSWORD@ac-xxxxx-shard-00-00.kguu8fx.mongodb.net:27017,ac-xxxxx-shard-00-01.kguu8fx.mongodb.net:27017,ac-xxxxx-shard-00-02.kguu8fx.mongodb.net:27017/placement-tracker?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin&retryWrites=true&w=majority

PORT=5000
CLIENT_ORIGIN=http://localhost:5173
